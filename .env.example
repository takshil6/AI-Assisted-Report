# Copy this file to `.env` and fill in real values. Never commit `.env` itself.

# Get a free Groq API key (no credit card required) at:
# https://console.groq.com/keys
GROQ_API_KEY=gsk_your-key-here

# Optional: SharePoint (Phase 5). Leave blank to save reports locally.
SHAREPOINT_SITE_URL=
SHAREPOINT_CLIENT_ID=
SHAREPOINT_CLIENT_SECRET=
SHAREPOINT_DOC_LIBRARY=Shared Documents
